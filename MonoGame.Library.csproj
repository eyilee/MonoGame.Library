<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|AnyCPU'" />
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|AnyCPU'" />
  <ItemGroup>
    <ShaderFiles Include="Shaders\Sdf\*.fx" />
  </ItemGroup>
  <ItemGroup>
    <EmbeddedResource Include="Shaders\Sdf\*.mgfxo" />
  </ItemGroup>
  <ItemGroup>
    <Compile Remove="samples\**" />
    <EmbeddedResource Remove="samples\**" />
    <None Remove="samples\**" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Gum.MonoGame" Version="2026.4.5.1" />
    <PackageReference Include="MonoGame.Framework.DesktopGL" Version="3.8.*">
      <PrivateAssets>All</PrivateAssets>
    </PackageReference>
  </ItemGroup>
  <Target Name="CompileShaders" BeforeTargets="Build" Inputs="@(ShaderFiles)" Outputs="@(ShaderFiles -> '%(RelativeDir)%(Filename).mgfxo')">
    <Exec Command="dotnet mgfxc %(ShaderFiles.Identity) %(RelativeDir)%(Filename).mgfxo /Profile:OpenGL" />
  </Target>
</Project>